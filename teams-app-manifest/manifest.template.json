{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.22/MicrosoftTeams.schema.json",
  "manifestVersion": "1.22",
  "version": "0.1.0",
  "id": "${MICROSOFT_APP_ID}",
  "developer": {
    "name": "Yum Donut",
    "websiteUrl": "https://kiwispin.github.io/yum-donut",
    "privacyUrl": "https://kiwispin.github.io/yum-donut",
    "termsOfUseUrl": "https://kiwispin.github.io/yum-donut"
  },
  "name": {
    "short": "YumDonut",
    "full": "Yum Donut Recognition"
  },
  "description": {
    "short": "Give Yum Donut recognition from Teams.",
    "full": "Mention YumDonut, tag classmates, and add donut emojis to send Yum Donut recognition from Microsoft Teams."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#ec4899",
  "bots": [
    {
      "botId": "${MICROSOFT_APP_ID}",
      "scopes": ["team"],
      "supportsFiles": false,
      "isNotificationOnly": false
    }
  ],
  "validDomains": [
    "${FUNCTION_HOSTNAME}"
  ],
  "webApplicationInfo": {
    "id": "${MICROSOFT_APP_ID}",
    "resource": "api://botid-${MICROSOFT_APP_ID}"
  }
}
